cat > rswsolutionz_rmm_all_in_one_autorun_fixed <<'EOF'
#!/bin/bash
# ============================
# Solutionz INC RMM All-in-One Auto Run (Linux)
# System Admin: RSW
# Last Updated: 2026-03-10
# Description: Remote two-phase installer for the Solutionz RMM collector.
# ============================

set -euo pipefail

if [ "${EUID}" -ne 0 ]; then
  echo "Please run this script with sudo."
  echo "Example: sudo ./rswsolutionz_rmm_all_in_one_autorun_fixed"
  exit 1
fi

MASTER_SCRIPT_NAME="rswsolutionz_rmm_all_in_one_autorun_fixed"
CONFIG_SCRIPT_NAME="rswsolutionz_rmm_config_check_v1"
CONNECTION_SCRIPT_NAME="rswsolutionz_rmm_collector_connection_check_v1"
SCRIPT_INSTALL_DIR="/usr/local/bin"
STATE_DIR="/var/lib/rswsolutionz-rmm"
STATE_FILE="${STATE_DIR}/install.state"
PHASE1_MARKER="phase1_complete"
COMPLETED_MARKER="completed"
LEGACY_RESUME_SERVICE="solutionz-rmm-resume.service"
MASTER_LOG="/var/log/RSWSolutionz_RMM_Collector.log"

mkdir -p "$STATE_DIR"
touch "$MASTER_LOG"
chmod 644 "$MASTER_LOG"
exec > >(tee -a "$MASTER_LOG")
exec 2>&1

read_state() {
  if [ -f "$STATE_FILE" ]; then
    cat "$STATE_FILE"
  else
    echo "new"
  fi
}

write_state() {
  printf '%s\n' "$1" > "$STATE_FILE"
}

step_message() {
  echo "------------------------------------------------------------"
  echo "Step $1: $2"
  echo "------------------------------------------------------------"
}

progress_message() {
  echo "   [+] $1"
}

confirm_from_tty() {
  local prompt="$1"
  local answer=""
  read -r -p "$prompt" answer < /dev/tty
  printf '%s' "$answer"
}

print_banner() {
cat <<'BANNER'
