create_config_script() {
  cat > "$SCRIPT_INSTALL_DIR/$CONFIG_SCRIPT_NAME" <<'CONFIG'
#!/bin/bash
set -euo pipefail
LOG_FILE="/var/log/RSWSolutionz_RMM_Config_Check.log"
exec > >(tee -a "$LOG_FILE")
exec 2>&1

echo "===== RSW Solutionz RMM Config Check ====="
echo "Date: $(date)"
echo "Hostname: $(hostname)"
echo ""
echo "[1] Domotz snap connections"
snap connections domotzpro-agent-publicstore || true
echo ""
echo "[2] SSH status"
systemctl status ssh --no-pager || true
echo ""
echo "[3] Firewall status"
ufw status verbose || true
echo ""
echo "[4] Hostname"
hostnamectl || true
echo ""
echo "[5] IP addressing"
ip a || true
echo ""
echo "[6] Routes"
ip route || true
echo ""
echo "[7] Netplan"
ls -lah /etc/netplan || true
for f in /etc/netplan/*.yaml; do
  [ -e "$f" ] && echo "--- $f ---" && cat "$f"
done
CONFIG
  chmod +x "$SCRIPT_INSTALL_DIR/$CONFIG_SCRIPT_NAME"
}

create_connection_script() {
  cat > "$SCRIPT_INSTALL_DIR/$CONNECTION_SCRIPT_NAME" <<'CONNECT'
#!/bin/bash
set -euo pipefail
LOG_FILE="/var/log/RSWSolutionz_RMM_Connection_Check.txt"
exec > >(tee -a "$LOG_FILE")
exec 2>&1

echo "===== RSW Solutionz RMM Connectivity Check ====="
echo "Date: $(date)"
echo "Hostname: $(hostname)"
echo ""
echo "[1] DNS"
getent hosts portal.domotz.com || true
getent hosts echo.domotz.com || true
echo ""
echo "[2] HTTPS / TCP"
nc -z -v -w3 portal.domotz.com 443 || true
nc -z -v -w3 api-us-east-1-cell-1.domotz.com 443 || true
nc -z -v -w3 api-eu-west-1-cell-1.domotz.com 443 || true
echo ""
echo "[3] ICMP"
ping -c 2 echo.domotz.com || true
echo ""
echo "[4] Snap / Ubuntu"
nc -z -v -w3 api.snapcraft.io 443 || true
nc -z -v -w3 login.ubuntu.com 443 || true
CONNECT
  chmod +x "$SCRIPT_INSTALL_DIR/$CONNECTION_SCRIPT_NAME"
}

phase1() {
  print_banner
  echo "This script is intended for remote use."
  echo "It does not auto-reboot and does not create any resume service."
  echo ""

  confirmation1="$(confirm_from_tty "Type 'yes' to proceed with Phase 1: ")"
  [ "$confirmation1" = "yes" ] || { echo "Confirmation not received. Exiting."; exit 1; }

  confirmation2="$(confirm_from_tty "Type 'yes' to proceed with Phase 1: ")"
  [ "$confirmation2" = "yes" ] || { echo "Confirmation not received. Exiting."; exit 1; }

  export DEBIAN_FRONTEND=noninteractive
  export NEEDRESTART_MODE=a

  step_message 1 "Updating system and installing key packages"
  echo "Apt::Cmd::Disable-Script-Warning true;" > /etc/apt/apt.conf.d/90disablescriptwarning
  apt update
  apt upgrade -y
  apt install -y net-tools openvswitch-switch traceroute dnsutils curl openssl netcat-openbsd nano iputils-ping openssh-server ufw

  step_message 2 "Loading tun module if not already loaded"
  modprobe tun || true
  grep -qxF "tun" /etc/modules || echo "tun" >> /etc/modules

  step_message 3 "Installing Domotz Pro agent via Snap Store"
  if snap list domotzpro-agent-publicstore >/dev/null 2>&1; then
    progress_message "Domotz Pro agent is already installed."
  else
    snap install domotzpro-agent-publicstore
  fi

  step_message 4 "Granting permissions to Domotz Pro agent"
  for permission in firewall-control network-observe raw-usb shutdown system-observe; do
    snap connect "domotzpro-agent-publicstore:$permission" || true
  done

  step_message 5 "Enabling UFW firewall and allowing SSH"
  ufw allow ssh || true
  ufw --force enable
  ufw status verbose || true

  step_message 6 "Allowing port 3000 in UFW"
  ufw allow 3000 || true

  step_message 7 "Configuring netplan for DHCP on attached NICs"
  cat > /etc/netplan/00-installer-config.yaml <<'NETPLAN'
network:
    version: 2
    ethernets:
        all-en:
            match:
                name: "en*"
            dhcp4: true
            dhcp6: false
            accept-ra: false
        all-eth:
            match:
                name: "eth*"
            dhcp4: true
            dhcp6: false
            accept-ra: false
NETPLAN
  chmod 600 /etc/netplan/00-installer-config.yaml
  rm -f /etc/netplan/50-cloud-init.yaml /etc/netplan/50-cloud-init.yaml.save /etc/netplan/90-solutionz-config.yaml
  netplan apply || true

  step_message 8 "Resolving VPN on Demand issue with DNS"
  if [ -e /etc/resolv.conf ] && [ ! -L /etc/resolv.conf ]; then
    mv /etc/resolv.conf "/etc/resolv.conf.bak.$(date +%Y%m%d%H%M%S)"
  fi
  rm -f /etc/resolv.conf
  ln -s /run/systemd/resolve/resolv.conf /etc/resolv.conf

  step_message 9 "Disabling cloud-init network configuration"
  echo "network: {config: disabled}" > /etc/cloud/cloud.cfg.d/99-disable-network-config.cfg

  step_message 10 "Enabling SSH service"
  systemctl enable ssh
  systemctl start ssh

  step_message 11 "Adding hostnames solzrmm and solz-rmm if they do not exist"
  grep -q '127.0.1.1    solzrmm' /etc/hosts || echo '127.0.1.1    solzrmm' >> /etc/hosts
  grep -q '127.0.1.1    solz-rmm' /etc/hosts || echo '127.0.1.1    solz-rmm' >> /etc/hosts

  step_message 12 "Appending kernel parameters to GRUB config"
  GRUB_FILE="/etc/default/grub"
  PARAMS="net.ifnames=0 biosdevname=0"
  cp "$GRUB_FILE" "${GRUB_FILE}.bak"
  if grep -q '^GRUB_CMDLINE_LINUX=' "$GRUB_FILE"; then
    grep -q "$PARAMS" "$GRUB_FILE" || sed -i "/^GRUB_CMDLINE_LINUX=/ s/\"\(.*\)\"/\"\1 $PARAMS\"/" "$GRUB_FILE"
  else
    echo "GRUB_CMDLINE_LINUX=\"$PARAMS\"" >> "$GRUB_FILE"
  fi

  step_message 13 "Configuring serial console access on Protectli"
  sed -i 's/^GRUB_CMDLINE_LINUX_DEFAULT=".*"/GRUB_CMDLINE_LINUX_DEFAULT="console=tty0 console=ttyS0,115200n8"/' /etc/default/grub || true
  mkdir -p /etc/systemd/system/serial-getty@ttyS0.service.d
  cat > /etc/systemd/system/serial-getty@ttyS0.service.d/override.conf <<'SERIAL'
[Service]
ExecStart=
ExecStart=-/sbin/agetty -o -p -- \u --keep-baud 115200,57600,38400,9600 ttyS0 vt220
SERIAL
  systemctl daemon-reexec || true
  systemctl daemon-reload || true
  systemctl enable serial-getty@ttyS0.service || true
  systemctl restart serial-getty@ttyS0.service || true

  step_message 14 "Updating banner"
  create_motd

  step_message 15 "Creating the renamed local RMM config check script"
  create_config_script

  step_message 16 "Creating the renamed local RMM connection check script"
  create_connection_script

  step_message 17 "Removing legacy resume services and applying executable permissions"
  systemctl stop "$LEGACY_RESUME_SERVICE" 2>/dev/null || true
  systemctl disable "$LEGACY_RESUME_SERVICE" 2>/dev/null || true
  rm -f "/etc/systemd/system/$LEGACY_RESUME_SERVICE"
  systemctl daemon-reload || true
  systemctl reset-failed || true

  step_message 18 "Updating GRUB and completing Phase 1"
  update-grub || true
  write_state "$PHASE1_MARKER"
  echo "------------------------------------------------------------"
  echo "   [+] Phase 1 complete. You can reboot now."
  echo "   [+] No auto reboot was triggered."
  echo "   [+] No resume service is enabled."
  echo "   [+] Reconnect remotely after the reboot and rerun:"
  echo "       sudo ./$MASTER_SCRIPT_NAME"
  echo "   [+] Master log: $MASTER_LOG"
  echo "------------------------------------------------------------"
}

phase2() {
  print_banner
  step_message 19 "Running the local RMM config check script"
  "$SCRIPT_INSTALL_DIR/$CONFIG_SCRIPT_NAME"

  step_message 20 "Running the local RMM connection check script"
  "$SCRIPT_INSTALL_DIR/$CONNECTION_SCRIPT_NAME"

  step_message 21 "Marking the install complete and showing log locations"
  write_state "$COMPLETED_MARKER"
  echo "------------------------------------------------------------"
  echo "   [+] Phase 2 complete."
  echo "   [+] Two-phase install finished successfully."
  echo "   [+] Master log: $MASTER_LOG"
  echo "   [+] Config log: /var/log/RSWSolutionz_RMM_Config_Check.log"
  echo "   [+] Connectivity log: /var/log/RSWSolutionz_RMM_Connection_Check.txt"
  echo "------------------------------------------------------------"
}

current_state="$(read_state)"
echo "===== RSW Solutionz RMM wrapper started at $(date '+%Y-%m-%d %H:%M:%S') ====="
echo "Current state: $current_state"

case "$current_state" in
  new)
    phase1
    ;;
  "$PHASE1_MARKER")
    phase2
    ;;
  "$COMPLETED_MARKER")
    print_banner
    echo "A previous two-phase install has already completed on this host."
    echo "Use the local scripts below for troubleshooting or re-validation:"
    echo "  $SCRIPT_INSTALL_DIR/$CONFIG_SCRIPT_NAME"
    echo "  $SCRIPT_INSTALL_DIR/$CONNECTION_SCRIPT_NAME"
    echo "To start over from scratch, remove $STATE_FILE and rerun the wrapper."
    ;;
  *)
    echo "Unknown install state: $current_state"
    echo "Please review or remove $STATE_FILE before rerunning the wrapper."
    exit 1
    ;;
esac
EOF
    ;;
esac
