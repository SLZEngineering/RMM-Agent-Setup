#!/usr/bin/env bash
set -Eeuo pipefail

###############################################################################
# Script: rswsolutionz_rmm_all_in_one_autorun
# Purpose: Remote-only two-phase installer/orchestrator for the RSW Solutionz
#          RMM / Domotz deployment workflow.
# Modified: 2026-03-11
# Maintainer: RSW
###############################################################################

SCRIPT_NAME="rswsolutionz_rmm_all_in_one_autorun"
SCRIPT_VERSION="2026-03-11"

STATE_DIR="/var/lib/rswsolutionz-rmm"
STATE_FILE="${STATE_DIR}/install.state"
LOG_FILE="/var/log/rswsolutionz_rmm_all_in_one_autorun.log"

LOCAL_BIN="/usr/local/bin"
SETUP_LOCAL="${LOCAL_BIN}/rswsolutionz_domotz_setup_rev2"
CONFIG_CHECK_LOCAL="${LOCAL_BIN}/rswsolutionz_rmm_config_check_v1"
COLLECTOR_CHECK_LOCAL="${LOCAL_BIN}/rswsolutionz_rmm_collector_connection_check_v1"

SETUP_URL="https://raw.githubusercontent.com/SLZEngineering/RMM-Agent-Setup/refs/heads/main/rswsolutionz_domotz_setup_rev2"
WRAPPER_URL="https://raw.githubusercontent.com/SLZEngineering/RMM-Agent-Setup/refs/heads/main/rswsolutionz_rmm_all_in_one_autorun"
CONFIG_CHECK_URL="https://raw.githubusercontent.com/SLZEngineering/RMM-Agent-Setup/refs/heads/main/rswsolutionz_rmm_config_check_v1"
COLLECTOR_CHECK_URL="https://raw.githubusercontent.com/SLZEngineering/RMM-Agent-Setup/refs/heads/main/rswsolutionz_rmm_collector_connection_check_v1"

RESUME_SERVICE_NAMES=(
  "solutionz-rmm-resume.service"
  "rswsolutionz-rmm-resume.service"
  "solutionz-rmm-resume.timer"
  "rswsolutionz-rmm-resume.timer"
)

on_error() {
  local exit_code=$?
  local line_no="${1:-unknown}"
  echo
  echo "[ERROR] ${SCRIPT_NAME} failed on line ${line_no} with exit code ${exit_code}."
  echo "[ERROR] Review ${LOG_FILE} for details."
  exit "${exit_code}"
}

trap 'on_error ${LINENO}' ERR

print_header() {
  echo "============================================================"
  echo " RSW Solutionz RMM All-In-One Auto Run"
  echo " Version : ${SCRIPT_VERSION}"
  echo " Script  : ${SCRIPT_NAME}"
  echo "============================================================"
  echo
}

require_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    echo "[ERROR] Please run this script with sudo or as root."
    exit 1
  fi
}

prepare_logging() {
  mkdir -p "${STATE_DIR}"
  touch "${LOG_FILE}"
  exec > >(tee -a "${LOG_FILE}") 2>&1
}

step() {
  echo
  echo "STEP $1 - $2"
  echo "------------------------------------------------------------"
}

warn() {
  echo "[WARN] $*"
}

info() {
  echo "[INFO] $*"
}

get_state() {
  if [[ -f "${STATE_FILE}" ]]; then
    tr -d '\r\n' < "${STATE_FILE}"
  else
    echo "new"
  fi
}

set_state() {
  local new_state="$1"
  mkdir -p "${STATE_DIR}"
  printf '%s\n' "${new_state}" > "${STATE_FILE}"
  info "Install state set to: ${new_state}"
}

prompt_for_confirmation() {
  echo "This script is designed for REMOTE use only."
  echo "It will perform a TWO-PHASE install."
  echo "There is NO auto reboot and NO resume service."
  echo
  echo "Phase 1 ends with:"
  echo "  Phase 1 complete. You can reboot now."
  echo
  read -r -p "Type yes to continue: " response

  case "${response}" in
    yes)
      info "Confirmation received. Continuing."
      ;;
    *)
      echo "Cancelled. No changes were made."
      exit 1
      ;;
  esac
}

download_file() {
  local url="$1"
  local destination="$2"

  curl -fL --retry 3 --retry-delay 2 -o "${destination}" "${url}"
  chmod +x "${destination}"
}

remove_legacy_resume_services() {
  local unit

  for unit in "${RESUME_SERVICE_NAMES[@]}"; do
    if systemctl list-unit-files | grep -Fq "${unit}"; then
      warn "Removing legacy unit: ${unit}"
      systemctl stop "${unit}" 2>/dev/null || true
      systemctl disable "${unit}" 2>/dev/null || true
    fi
    rm -f "/etc/systemd/system/${unit}" || true
  done

  systemctl daemon-reload || true
  systemctl reset-failed || true
}

download_repo_scripts() {
  mkdir -p "${LOCAL_BIN}"

  info "Downloading setup script..."
  download_file "${SETUP_URL}" "${SETUP_LOCAL}"

  info "Downloading config check script..."
  download_file "${CONFIG_CHECK_URL}" "${CONFIG_CHECK_LOCAL}"

  info "Downloading collector connection check script..."
  download_file "${COLLECTOR_CHECK_URL}" "${COLLECTOR_CHECK_LOCAL}"
}

syntax_check_repo_scripts() {
  bash -n "${SETUP_LOCAL}"
  bash -n "${CONFIG_CHECK_LOCAL}"
  bash -n "${COLLECTOR_CHECK_LOCAL}"
  info "Syntax check passed for setup and validation scripts."
}

run_phase_1() {
  step 1 "Display run information"
  info "Starting Phase 1."

  step 2 "Prompt for confirmation"
  prompt_for_confirmation

  step 3 "Remove legacy resume services"
  remove_legacy_resume_services

  step 4 "Create working state folder"
  mkdir -p "${STATE_DIR}"
  info "State directory ready: ${STATE_DIR}"

  step 5 "Download the latest setup and check scripts"
  download_repo_scripts

  step 6 "Syntax check the downloaded scripts"
  syntax_check_repo_scripts

  step 7 "Run the setup script"
  bash "${SETUP_LOCAL}"

  step 8 "Write the Phase 1 completion state"
  set_state "phase1_complete"

  step 9 "Display reboot instruction"
  echo
  echo "Phase 1 complete. You can reboot now."
  echo "After reboot, reconnect remotely and run this same script again."
}

run_phase_2() {
  step 10 "Confirm Phase 1 was completed"
  if [[ "$(get_state)" != "phase1_complete" ]]; then
    echo "[ERROR] Phase 2 cannot start because the state is not phase1_complete."
    echo "[ERROR] Current state: $(get_state)"
    exit 1
  fi

  step 11 "Refresh the local scripts"
  download_repo_scripts

  step 12 "Syntax check the validation scripts"
  syntax_check_repo_scripts

  step 13 "Run the configuration validation script"
  bash "${CONFIG_CHECK_LOCAL}"

  step 14 "Run the collector connection validation script"
  bash "${COLLECTOR_CHECK_LOCAL}"

  step 15 "Write the completed state"
  set_state "completed"

  step 16 "Display final completion message"
  echo
  echo "Phase 2 complete. Installation and validation are finished."
}

show_completed_message() {
  echo
  echo "The two-phase process has already completed on this device."
  echo "Current state: $(get_state)"
  echo
  echo "Use these commands for validation if needed:"
  echo "  sudo ${CONFIG_CHECK_LOCAL}"
  echo "  sudo ${COLLECTOR_CHECK_LOCAL}"
}

main() {
  require_root
  prepare_logging
  print_header

  local current_state
  current_state="$(get_state)"

  info "Current install state: ${current_state}"
  info "Wrapper source URL: ${WRAPPER_URL}"

  case "${current_state}" in
    new)
      run_phase_1
      ;;
    phase1_complete)
      run_phase_2
      ;;
    completed)
      show_completed_message
      ;;
    *)
      warn "Unknown state value found: ${current_state}"
      warn "Resetting state to new and exiting for safety."
      set_state "new"
      echo "Please run the script again."
      exit 1
      ;;
  esac
}

main "$@"
    ;;
esac
