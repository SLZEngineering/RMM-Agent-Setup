#!/usr/bin/env bash
set -Eeuo pipefail
trap 'echo " [!] ERROR on line ${LINENO}: ${BASH_COMMAND}"' ERR

###############################################################################
# Script: rswsolutionz_domotz_setup_rev3_remote_staged
# Company: Solutionz INC / RSW
# Last Updated: 2026-03-18
# Description: Install and configure the Solutionz RMM Collector image.
# Usage: Remote-only execution. Manual reboot at the end.
###############################################################################

LOG_FILE="RSWSolutionz_RMM_Collector.log"
STATE_DIR="/var/lib/rswsolutionz-rmm"
STATE_FILE="${STATE_DIR}/install.state"
NETPLAN_FILE="/etc/netplan/00-installer-config.yaml"
GRUB_FILE="/etc/default/grub"
MOTD_FILE="/etc/update-motd.d/slz-rsw-login"
SERIAL_DROPIN_DIR="/etc/systemd/system/serial-getty@ttyS0.service.d"
SERIAL_DROPIN_FILE="${SERIAL_DROPIN_DIR}/override.conf"
RESOLV_TARGET="/run/systemd/resolve/resolv.conf"
RESOLV_FILE="/etc/resolv.conf"

exec > >(tee -ia "${LOG_FILE}") 2>&1

step_message() {
  echo "------------------------------------------------------------"
  echo "Step $1: $2"
  echo "------------------------------------------------------------"
}

progress_message() {
  echo " [+] $1"
}

error_exit() {
  echo " [!] ERROR: $1"
  exit 1
}

require_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    error_exit "Please run this script with sudo or as root."
  fi
}

prompt_confirmation() {
  echo -e "\e[36m
  _____   ____    _      _    _   _____   _    ____   _     _
 / ____| / __ \  | |    | |  | | |_   _| | |  / __ \ | \   | |  _____
| (___  | |  | | | |    | |  | |   | |   | | | |  | ||  \  | | |___ /
 \___ \ | |  | | | |    | |  | |   | |   | | | |  | || |\ \| |   / /
 ____) || |__| | | |___ | |__| |   | |   | | | |__| || |  \  |  / /__
|_____/  \____/  |_____| \____/    |_|   |_|  \____/ |_|   \_| /_____|

Welcome to the Solutionz INC configuration script.
\e[0m"

  echo "------------------------------------------------------------"
  echo "This script will perform the following actions:"
  echo "1. Update system and install key packages"
  echo "2. Verify required packages were installed"
  echo "3. Enable and verify SSH service early"
  echo "4. Load the 'tun' module if not already loaded"
  echo "5. Install Domotz Pro agent via Snap Store"
  echo "6. Grant permissions to Domotz Pro agent"
  echo "7. Enable UFW firewall and verify status"
  echo "8. Write netplan for eth0 DHCP and eth1 DHCP with preferred routing on eth0"
  echo "9. Repair resolv.conf behavior from prior script"
  echo "10. Disable cloud-init network configuration"
  echo "11. Add hostnames solzrmm and solz-rmm"
  echo "12. Append kernel parameters to GRUB config"
  echo "13. Configure serial console access on Protectli"
  echo "14. Update banner"
  echo "15. Stage netplan without applying it"
  echo "16. Run final validation summary"
  echo "------------------------------------------------------------"
  echo "Disclaimer:"
  echo "1. Purpose: This script is designed for the Solutionz RMM Collector, created by RSW."
  echo "2. By proceeding, you confirm that system configurations will be modified."
  echo "3. This script is intended for REMOTE use only."
  echo "4. There is NO automatic reboot."
  echo "5. Network changes are staged and will apply only after reboot."
  echo "6. Collector connectivity validation must be run after reboot."
  echo

  read -r -p "Type 'yes' to proceed: " confirmation1
  [[ "${confirmation1}" == "yes" ]] || error_exit "Confirmation not received. Exiting script."

  echo "------------------------------------------------------------"
  echo "Please confirm again to proceed."
  read -r -p "Type 'yes' to proceed: " confirmation2
  [[ "${confirmation2}" == "yes" ]] || error_exit "Confirmation not received. Exiting script."
}

write_netplan_config() {
  cat > "${NETPLAN_FILE}" <<'YAML'
network:
  version: 2
  renderer: networkd
  ethernets:
    eth0:
      dhcp4: true
      dhcp6: false
      dhcp4-overrides:
        route-metric: 100

    eth1:
      dhcp4: true
      dhcp6: false
      dhcp4-overrides:
        route-metric: 200
YAML
  chmod 600 "${NETPLAN_FILE}"
}

remove_stale_cloud_init_netplans() {
  progress_message "Removing stale cloud-init netplan files if present..."
  shopt -s nullglob
  local files=(/etc/netplan/50-cloud-init*)
  if (( ${#files[@]} > 0 )); then
    rm -f "${files[@]}"
    progress_message "Removed stale cloud-init netplan files."
  else
    progress_message "No stale cloud-init netplan files found."
  fi
  shopt -u nullglob
}

ensure_host_entry() {
  local entry="$1"
  if grep -qxF "${entry}" /etc/hosts; then
    progress_message "Hostname entry '${entry}' already exists."
  else
    echo "${entry}" >> /etc/hosts
    progress_message "Hostname entry '${entry}' added successfully."
  fi
}

append_grub_param_if_missing() {
  local param="$1"
  if grep -Fq "${param}" "${GRUB_FILE}"; then
    progress_message "GRUB parameter '${param}' already present."
  else
    sed -i "/^GRUB_CMDLINE_LINUX=/ s/\"$/ ${param}\"/" "${GRUB_FILE}"
    progress_message "Added GRUB parameter '${param}'."
  fi
}

ensure_grub_default_serial() {
  local serial_params='console=tty0 console=ttyS0,115200n8'

  if grep -q '^GRUB_CMDLINE_LINUX_DEFAULT=' "${GRUB_FILE}"; then
    if grep -Fq 'console=ttyS0,115200n8' "${GRUB_FILE}"; then
      progress_message "Serial console parameters already present in GRUB_CMDLINE_LINUX_DEFAULT."
    else
      sed -i "/^GRUB_CMDLINE_LINUX_DEFAULT=/ s/\"$/ ${serial_params}\"/" "${GRUB_FILE}"
      progress_message "Appended serial console parameters to GRUB_CMDLINE_LINUX_DEFAULT."
    fi
  else
    echo "GRUB_CMDLINE_LINUX_DEFAULT=\"${serial_params}\"" >> "${GRUB_FILE}"
    progress_message "Created GRUB_CMDLINE_LINUX_DEFAULT with serial console parameters."
  fi
}

repair_resolv_conf() {
  progress_message "Ensuring systemd-resolved is enabled..."
  systemctl enable --now systemd-resolved

  if [[ -L "${RESOLV_FILE}" ]]; then
    local current_target
    current_target="$(readlink -f "${RESOLV_FILE}")"
    if [[ "${current_target}" == "${RESOLV_TARGET}" ]]; then
      progress_message "${RESOLV_FILE} already points to ${RESOLV_TARGET}."
      ls -l "${RESOLV_FILE}"
      return 0
    fi
  fi

  progress_message "Repairing ${RESOLV_FILE} symlink to ${RESOLV_TARGET}..."
  rm -f "${RESOLV_FILE}"
  ln -s "${RESOLV_TARGET}" "${RESOLV_FILE}"
  ls -l "${RESOLV_FILE}"
}

install_missing_packages() {
  local packages=(
    net-tools
    openvswitch-switch
    traceroute
    dnsutils
    curl
    openssl
    netcat-openbsd
    nano
    iputils-ping
    ufw
    snapd
    openssh-server
  )

  local missing=()
  for pkg in "${packages[@]}"; do
    if ! dpkg -s "${pkg}" >/dev/null 2>&1; then
      missing+=("${pkg}")
    fi
  done

  if (( ${#missing[@]} > 0 )); then
    progress_message "Installing missing packages: ${missing[*]}"
    apt install -y "${missing[@]}"
  else
    progress_message "All required packages are already installed."
  fi
}

wait_for_snapd() {
  local tries=0
  until systemctl is-active snapd >/dev/null 2>&1; do
    ((tries++))
    if (( tries > 12 )); then
      error_exit "snapd did not become active in time."
    fi
    sleep 2
  done
}

verify_required_packages() {
  progress_message "Verifying required packages..."
  local required=(
    nano
    iputils-ping
    ufw
    openssh-server
  )

  for pkg in "${required[@]}"; do
    if dpkg -s "${pkg}" >/dev/null 2>&1; then
      progress_message "Verified package installed: ${pkg}"
    else
      error_exit "Required package missing after install: ${pkg}"
    fi
  done

  command -v nano >/dev/null 2>&1 || error_exit "nano command not found after install."
  command -v ping >/dev/null 2>&1 || error_exit "ping command not found after install."
  command -v ufw >/dev/null 2>&1 || error_exit "ufw command not found after install."
  command -v ssh >/dev/null 2>&1 || progress_message "ssh client command not present; server package may still be installed."
}

verify_ssh_service() {
  progress_message "Enabling and starting SSH service..."
  systemctl enable --now ssh

  if systemctl is-enabled ssh >/dev/null 2>&1; then
    progress_message "SSH service is enabled."
  else
    error_exit "SSH service is not enabled."
  fi

  if systemctl is-active ssh >/dev/null 2>&1; then
    progress_message "SSH service is active."
  else
    error_exit "SSH service is not active."
  fi

  systemctl status ssh --no-pager || true
}

verify_ufw() {
  progress_message "Verifying UFW..."
  command -v ufw >/dev/null 2>&1 || error_exit "ufw command not found."

  progress_message "Allowing SSH through UFW..."
  ufw allow ssh || true

  progress_message "Allowing port 3000 through UFW..."
  ufw allow 3000/tcp || true

  progress_message "Enabling UFW..."
  ufw --force enable

  progress_message "Checking UFW status..."
  ufw status verbose || error_exit "Unable to retrieve UFW status."
}

final_summary_check() {
  echo
  echo "============================================================"
  echo "FINAL VALIDATION SUMMARY"
  echo "============================================================"

  echo
  echo "[Package Status]"
  for pkg in nano iputils-ping ufw openssh-server; do
    if dpkg -s "${pkg}" >/dev/null 2>&1; then
      echo "PASS - ${pkg} installed"
    else
      echo "FAIL - ${pkg} missing"
    fi
  done

  echo
  echo "[Command Availability]"
  command -v nano >/dev/null 2>&1 && echo "PASS - nano command found" || echo "FAIL - nano command missing"
  command -v ping >/dev/null 2>&1 && echo "PASS - ping command found" || echo "FAIL - ping command missing"
  command -v ufw >/dev/null 2>&1 && echo "PASS - ufw command found" || echo "FAIL - ufw command missing"

  echo
  echo "[SSH Service]"
  if systemctl is-enabled ssh >/dev/null 2>&1; then
    echo "PASS - ssh service enabled"
  else
    echo "FAIL - ssh service not enabled"
  fi

  if systemctl is-active ssh >/dev/null 2>&1; then
    echo "PASS - ssh service active"
  else
    echo "FAIL - ssh service not active"
  fi

  echo
  echo "[UFW Status]"
  ufw status verbose || echo "FAIL - unable to retrieve UFW status"

  echo
  echo "[DNS / resolv.conf]"
  ls -l "${RESOLV_FILE}" || true

  echo
  echo "[Netplan Files]"
  ls -l /etc/netplan || true

  echo
  echo "[Host Entries]"
  grep -E 'solzrmm|solz-rmm' /etc/hosts || true

  echo
  echo "[State File]"
  cat "${STATE_FILE}" || true

  echo
  echo "============================================================"
}

main() {
  require_root
  mkdir -p "${STATE_DIR}"

  export DEBIAN_FRONTEND=noninteractive
  export NEEDRESTART_MODE=a

  prompt_confirmation

  step_message 1 "Updating system and installing key packages"
  progress_message "Suppressing apt script warnings..."
  echo 'Apt::Cmd::Disable-Script-Warning true;' > /etc/apt/apt.conf.d/90disablescriptwarning

  progress_message "Updating package lists..."
  apt update

  progress_message "Upgrading packages..."
  apt upgrade -y

  progress_message "Installing required diagnostic and connectivity tools..."
  install_missing_packages

  step_message 2 "Verifying required packages"
  verify_required_packages

  step_message 3 "Enable and verify SSH service early"
  verify_ssh_service

  step_message 4 "Loading tun module if not already loaded"
  progress_message "Loading 'tun' module..."
  modprobe tun
  grep -qxF 'tun' /etc/modules || echo 'tun' >> /etc/modules

  step_message 5 "Installing Domotz Pro agent via Snap Store"
  progress_message "Ensuring snapd is enabled..."
  systemctl enable --now snapd || true
  systemctl enable --now snapd.socket || true

  progress_message "Waiting for snapd service to become active..."
  wait_for_snapd

  if ! snap list | awk '{print $1}' | grep -qx 'domotzpro-agent-publicstore'; then
    progress_message "Installing Domotz Pro agent..."
    snap install domotzpro-agent-publicstore
  else
    progress_message "Domotz Pro agent is already installed."
  fi

  step_message 6 "Granting permissions to Domotz Pro agent"
  permissions=("firewall-control" "network-observe" "raw-usb" "shutdown" "system-observe")
  for permission in "${permissions[@]}"; do
    progress_message "Connecting Domotz Pro agent: ${permission}..."
    snap connect "domotzpro-agent-publicstore:${permission}" || true
  done

  step_message 7 "Enable UFW firewall and verify status"
  verify_ufw

  step_message 8 "Preparing netplan for DHCP on eth0 and eth1"
  progress_message "Backing up existing netplan if present..."
  if [[ -f "${NETPLAN_FILE}" ]]; then
    cp "${NETPLAN_FILE}" "${NETPLAN_FILE}.bak.$(date +%Y%m%d%H%M%S)"
  fi

  progress_message "Writing netplan configuration file..."
  write_netplan_config
  remove_stale_cloud_init_netplans

  step_message 9 "Resolve VPN on Demand issue with DNS"
  repair_resolv_conf

  step_message 10 "Disable cloud-init network configuration"
  progress_message "Disabling cloud-init network configuration..."
  mkdir -p /etc/cloud/cloud.cfg.d
  cat > /etc/cloud/cloud.cfg.d/99-disable-network-config.cfg <<'EOF'
network: {config: disabled}
EOF

  step_message 11 "Adding hostnames solzrmm and solz-rmm if they do not exist"
  ensure_host_entry "127.0.1.1    solzrmm"
  ensure_host_entry "127.0.1.1    solz-rmm"

  step_message 12 "Automatically append kernel parameters to GRUB config"
  progress_message "Backing up GRUB configuration..."
  cp "${GRUB_FILE}" "${GRUB_FILE}.bak.$(date +%Y%m%d%H%M%S)"

  if ! grep -q '^GRUB_CMDLINE_LINUX=' "${GRUB_FILE}"; then
    echo 'GRUB_CMDLINE_LINUX=""' >> "${GRUB_FILE}"
  fi

  append_grub_param_if_missing 'net.ifnames=0'
  append_grub_param_if_missing 'biosdevname=0'

  step_message 13 "Configuring Serial Console Access on Protectli"
  progress_message "Editing GRUB configuration for serial console..."
  ensure_grub_default_serial

  progress_message "Creating systemd drop-in for serial-getty@ttyS0..."
  mkdir -p "${SERIAL_DROPIN_DIR}"
  cat > "${SERIAL_DROPIN_FILE}" <<'EOF'
[Service]
ExecStart=
ExecStart=-/sbin/agetty -o '-p -- \u' --keep-baud 115200,57600,38400,9600 ttyS0 vt220
EOF

  progress_message "Reloading systemd daemon..."
  systemctl daemon-reexec
  systemctl daemon-reload

  progress_message "Enabling and starting serial-getty@ttyS0 service..."
  systemctl enable serial-getty@ttyS0.service
  systemctl restart serial-getty@ttyS0.service

  progress_message "Verifying agetty process on ttyS0..."
  ps aux | grep '[a]getty' | grep ttyS0 || echo "Warning: agetty not detected on ttyS0"

  step_message 14 "Update Banner"
  progress_message "Adding banner..."
  cat > "${MOTD_FILE}" <<'EOF'
#!/usr/bin/env bash
YELLOW='\033[1;33m'
CYAN='\033[1;36m'
NC='\033[0m'

echo -e "${CYAN}
  _____   ____    _      _    _   _____   _    ____   _     _
 / ____| / __ \  | |    | |  | | |_   _| | |  / __ \ | \   | |  _____
| (___  | |  | | | |    | |  | |   | |   | | | |  | ||  \  | | |___ /
 \___ \ | |  | | | |    | |  | |   | |   | | | |  | || |\ \| |   / /
 ____) || |__| | | |___ | |__| |   | |   | | | |__| || |  \  |  / /__
|_____/  \____/  |_____| \____/    |_|   |_|  \____/ |_|   \_| /_____|
${NC}"

echo -e "${YELLOW}Welcome to the Solutionz RMM Collector Login.${NC}"
echo "============================================================"
echo "Solutionz RMM System Admin: RSW"
echo "------------------------------------------------------------"
hostnamectl
echo "------------------------------------------------------------"
ip a
echo "------------------------------------------------------------"
echo "Uptime: $(uptime -p)"
echo -e "${YELLOW}Kernel: $(uname -r)${NC}"
echo "CPU: $(lscpu | awk -F: '/Model name/ {print $2}' | xargs)"
echo "Memory: $(free -h | awk '/Mem:/ {print $3 "/" $2}')"
echo "Disk: $(df -h / | awk 'NR==2 {print $3 "/" $2 " used"}')"
echo "IP Addr: $(hostname -I | xargs)"
echo "============================================================"
echo "System information as of $(date)"
EOF
  chmod +x "${MOTD_FILE}"

  step_message 15 "Staging netplan for later application"
  progress_message "Validating netplan configuration syntax..."
  netplan generate

  progress_message "Netplan configuration staged successfully."
  progress_message "Skipping netplan apply to avoid interrupting remote access."
  progress_message "Network changes will take effect after reboot."

  update-grub
  printf 'phase1_complete\n' > "${STATE_FILE}"

  step_message 16 "Running final validation summary"
  final_summary_check

  echo "------------------------------------------------------------"
  echo " [+] Setup completed successfully!"
  echo " [+] Completion Time: $(date)"
  echo " [+] Hostname: $(hostname)"
  echo " [+] Script Version: rev3-remote-staged-2026-03-18"
  echo " [+] State File: ${STATE_FILE}"
  echo "------------------------------------------------------------"
  echo "Netplan changes were staged but NOT applied automatically."
  echo "This was done intentionally to preserve the remote session."
  echo "Reboot the device when ready for the staged network configuration to take effect."
  echo "Run the collector connection check only after reboot."
}

main "$@"
